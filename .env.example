# MongoDB
MongoDB_Client="mongodb+srv://<username>:<password>@<cluster-url>/"

# Voyage AI
VOYAGE_API_KEY="your-voyage-api-key"

# LLM Sandbox
LLMSANDBOX_API_ENDPOINT="https://your-api-endpoint.example.com/api"
LLMSANDBOX_API_KEY="your-llm-sandbox-api-key"

# Optional adaptive polling overrides
# I set these defaults to match the adaptive polling guide.
# In plain English: start fast, back off gradually, and stop pretending that
# hammering the conversation endpoint every fixed interval is a good idea.
LLMSANDBOX_POLL_INITIAL_MS="300"
LLMSANDBOX_POLL_BACKOFF_FACTOR="1.5"
LLMSANDBOX_POLL_MAX_MS="5000"
LLMSANDBOX_POLL_MAX_RETRIES="5"
LLMSANDBOX_REQUEST_TIMEOUT_SECONDS="30"